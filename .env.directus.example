# ─── Directus environment variables ──────────────────────────────────────────
# Copy this file to .env.directus (or set these directly in docker-compose.yml)
# Never commit .env.directus to git.
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret — generate with: openssl rand -hex 32
DIRECTUS_SECRET=replace-with-a-long-random-string

# First-time admin credentials
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=changeme123

# Directus admin static token — generate in Directus → Settings → API Tokens
# Required by the rss-sync service to write articles and upload images
DIRECTUS_TOKEN=replace-with-your-directus-admin-token

# Port the rss-sync HTTP server listens on (default: 3000, internal Docker network only)
SERVER_PORT=3000
